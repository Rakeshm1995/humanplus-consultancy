@using HumanPlus.Domain.Entities.Candidates
@using HumanPlus.Domain.Entities.MasterData
@using HumanPlus.Domain.Enums
@model Candidate
@{
    ViewData["Title"] = "My Profile";
}

<div class="container py-4">
    <h2><i class="bi bi-person-badge"></i> My Profile</h2>
    <hr />
    <form asp-action="SaveProfile" method="post">
        <div class="row g-3">
            <h5 class="mt-3">Personal Information</h5>
            <div class="col-md-4">
                <label class="form-label">Father's Name</label>
                <input asp-for="FatherName" class="form-control" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Mother's Name</label>
                <input asp-for="MotherName" class="form-control" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Gender</label>
                <select asp-for="Gender" asp-items="Html.GetEnumSelectList<Gender>()" class="form-select">
                    <option value="">-- Select --</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Date of Birth</label>
                <input asp-for="DateOfBirth" type="date" class="form-control" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Marital Status</label>
                <select asp-for="MaritalStatus" asp-items="Html.GetEnumSelectList<MaritalStatus>()" class="form-select">
                    <option value="">-- Select --</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Blood Group</label>
                <input asp-for="BloodGroup" class="form-control" placeholder="e.g. A+" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Aadhaar Number</label>
                <input asp-for="AadhaarNumber" class="form-control" />
            </div>
            <div class="col-md-4">
                <label class="form-label">PAN Number</label>
                <input asp-for="PanNumber" class="form-control" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Alternate Mobile</label>
                <input asp-for="AlternateMobile" class="form-control" />
            </div>

            <h5 class="mt-3">Address</h5>
            <div class="col-12">
                <label class="form-label">Current Address</label>
                <textarea asp-for="CurrentAddress" class="form-control" rows="2"></textarea>
            </div>
            <div class="col-12">
                <label class="form-label">Permanent Address</label>
                <textarea asp-for="PermanentAddress" class="form-control" rows="2"></textarea>
            </div>
            <div class="col-md-4">
                <label class="form-label">State</label>
                <select asp-for="StateId" asp-items='new SelectList(ViewBag.States, "Id", "Name")' class="form-select">
                    <option value="">-- Select --</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">District</label>
                <select asp-for="DistrictId" asp-items='new SelectList(ViewBag.Districts, "Id", "Name")' class="form-select">
                    <option value="">-- Select --</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">PIN Code</label>
                <input asp-for="PinCode" class="form-control" />
            </div>

            <h5 class="mt-3">Experience</h5>
            <div class="col-md-3">
                <div class="form-check mt-2">
                    <input asp-for="IsFresher" class="form-check-input" />
                    <label class="form-check-label">I am a Fresher</label>
                </div>
            </div>
            <div class="col-md-3">
                <label class="form-label">Total Experience (Years)</label>
                <input asp-for="TotalExperienceYears" class="form-control" type="number" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Previous Employer</label>
                <input asp-for="PreviousEmployer" class="form-control" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Previous Designation</label>
                <input asp-for="PreviousDesignation" class="form-control" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Previous Salary</label>
                <input asp-for="PreviousSalary" class="form-control" type="number" step="0.01" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Previous Industry</label>
                <select asp-for="PreviousIndustryId" asp-items='new SelectList(ViewBag.Industries, "Id", "Name")' class="form-select">
                    <option value="">-- Select --</option>
                </select>
            </div>

            <h5 class="mt-3">Job Preferences</h5>
            <div class="col-md-4">
                <label class="form-label">Preferred Industry</label>
                <select asp-for="PreferredIndustryId" asp-items='new SelectList(ViewBag.Industries, "Id", "Name")' class="form-select">
                    <option value="">-- Select --</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Preferred Location</label>
                <input asp-for="PreferredLocation" class="form-control" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Expected Salary</label>
                <input asp-for="ExpectedSalary" class="form-control" type="number" step="0.01" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Shift Preference</label>
                <select asp-for="ShiftPreference" asp-items="Html.GetEnumSelectList<ShiftPreference>()" class="form-select">
                    <option value="">-- Select --</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Employment Type</label>
                <select asp-for="PreferredEmploymentType" asp-items="Html.GetEnumSelectList<EmploymentType>()" class="form-select">
                    <option value="">-- Select --</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">&nbsp;</label>
                <div class="form-check mt-2">
                    <input asp-for="WillingToRelocate" class="form-check-input" />
                    <label class="form-check-label">Willing to Relocate</label>
                </div>
            </div>

            <h5 class="mt-3">Skills</h5>
            <div class="col-12">
                <div class="row g-2">
                    @foreach (var skill in (List<Skill>)ViewBag.Skills)
                    {
                        <div class="col-md-3 col-4">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="SelectedSkillIds" value="@skill.Id"
                                @(Model.Skills?.Any(s => s.SkillId == skill.Id) == true ? "checked" : "") />
                                <label class="form-check-label">@skill.Name</label>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <h5 class="mt-3">Education</h5>
            <div class="col-12">
                <table class="table table-bordered" id="educationTable">
                    <thead class="table-light">
                        <tr>
                            <th>Qualification</th>
                            <th>Board/University</th>
                            <th>Passing Year</th>
                            <th>Percentage/Grade</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Educations?.Any() == true)
                        {
                            var i = 0;
                            foreach (var edu in Model.Educations)
                            {
                                <tr>
                                    <td>
                                        <select name="Educations[@i].QualificationId" class="form-select">
                                            <option value="">-- Select --</option>
                                            @foreach (var q in (List<Qualification>)ViewBag.Qualifications)
                                            {
                                                <option value="@q.Id" selected="@(edu.QualificationId == q.Id)">@q.Name</option>
                                            }
                                        </select>
                                    </td>
                                    <td><input name="Educations[@i].BoardOrUniversity" value="@edu.BoardOrUniversity" class="form-control" /></td>
                                    <td><input name="Educations[@i].PassingYear" value="@edu.PassingYear" class="form-control" type="number" /></td>
                                    <td><input name="Educations[@i].PercentageOrGrade" value="@edu.PercentageOrGrade" class="form-control" /></td>
                                    <td><button type="button" class="btn btn-danger btn-sm removeRow">&times;</button></td>
                                </tr>
                                i++;
                            }
                        }
                    </tbody>
                </table>
                <button type="button" class="btn btn-outline-primary btn-sm" onclick="addEducationRow()">+ Add Education</button>
            </div>

            <div class="col-12 mt-4">
                <button type="submit" class="btn btn-primary px-4">Save Profile</button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        let eduIndex = @(Model.Educations?.Count() ?? 0);
        function addEducationRow() {
            const row = `<tr>
                <td><select name="Educations[${eduIndex}].QualificationId" class="form-select">
                    <option value="">-- Select --</option>
                    @foreach (var q in (List<Qualification>)ViewBag.Qualifications)
                    {
                        <option value="@q.Id">@q.Name</option>
                    }
                </select></td>
                <td><input name="Educations[${eduIndex}].BoardOrUniversity" class="form-control" /></td>
                <td><input name="Educations[${eduIndex}].PassingYear" class="form-control" type="number" /></td>
                <td><input name="Educations[${eduIndex}].PercentageOrGrade" class="form-control" /></td>
                <td><button type="button" class="btn btn-danger btn-sm removeRow">&times;</button></td>
            </tr>`;
            document.getElementById('educationTable').querySelector('tbody').insertAdjacentHTML('beforeend', row);
            eduIndex++;
        }
        document.addEventListener('click', function (e) {
            if (e.target.classList.contains('removeRow')) {
                e.target.closest('tr').remove();
            }
        });
    </script>
}

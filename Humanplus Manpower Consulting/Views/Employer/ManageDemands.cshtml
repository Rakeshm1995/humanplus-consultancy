@using HumanPlus.Domain.Entities.Jobs
@using HumanPlus.Domain.Enums
@model List<JobDemand>
@{
    ViewData["Title"] = "Manage Demands";
}

<div class="container py-4">

    <div class="d-flex align-items-center justify-content-between mb-2">
        <h2 class="mb-0"><i class="bi bi-list-check"></i> My Job Demands</h2>
        <div>
            <a asp-action="PostDemand" class="btn btn-primary rounded-pill me-2"><i class="bi bi-plus"></i> Post New Demand</a>
            <a asp-action="Dashboard" class="btn btn-outline-secondary rounded-pill"><i class="bi bi-arrow-left"></i> Back to Dashboard</a>
        </div>
    </div>
    <hr />

    @* Search / Filter *@
    <form method="get" class="row g-2 mb-3 align-items-end">
        <div class="col-md-3">
            <input type="text" name="search" class="form-control form-control-sm" placeholder="Search by job title..." value="@ViewBag.Search" />
        </div>
        <div class="col-md-3">
            <select name="status" class="form-select form-select-sm" onchange="this.form.submit()">
                <option value="">All Statuses</option>
                @foreach (var s in Enum.GetValues<JobDemandStatus>())
                {
                    <option value="@s" selected="@(ViewBag.SelectedStatus == s.ToString())">@s</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary btn-sm w-100"><i class="bi bi-search me-1"></i>Filter</button>
        </div>
        <div class="col-md-2">
            <a asp-action="ManageDemands" class="btn btn-outline-secondary btn-sm w-100"><i class="bi bi-arrow-clockwise me-1"></i>Reset</a>
        </div>
    </form>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>No demands posted yet.
            <a asp-action="PostDemand" class="alert-link">Post your first demand</a>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-3">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 small">
                        <thead class="table-light">
                            <tr>
                                <th class="px-3 py-3">Job Title</th>
                                <th class="py-3">Openings</th>
                                <th class="py-3">Skills</th>
                                <th class="py-3">Experience</th>
                                <th class="py-3">Salary Range</th>
                                <th class="py-3">Location</th>
                                <th class="py-3">Status</th>
                                <th class="py-3">Posted</th>
                                <th class="text-center py-3">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var job in Model)
                            {
                                <tr>
                                    <td class="px-3 fw-medium">@job.JobTitle</td>
                                    <td><span class="badge bg-secondary-subtle text-secondary">@job.NumberOfOpenings</span></td>
                                    <td class="text-muted">@Truncate(job.RequiredSkills, 30)</td>
                                    <td>@(job.MinExperience.HasValue ? $"{job.MinExperience}-{job.MaxExperience} yrs" : "-")</td>
                                    <td>@(job.MinSalary.HasValue ? $"₹{job.MinSalary:N0} - ₹{job.MaxSalary:N0}" : "-")</td>
                                    <td>@job.WorkLocation</td>
                                    <td>
                                        <span class="badge bg-@(job.Status switch {
                                            JobDemandStatus.PendingApproval => "warning text-dark",
                                            JobDemandStatus.Approved => "success",
                                            JobDemandStatus.CandidatesAssigned => "info",
                                            JobDemandStatus.InterviewScheduled => "indigo",
                                            JobDemandStatus.Fulfilled => "primary",
                                            JobDemandStatus.Closed => "secondary",
                                            JobDemandStatus.Cancelled => "danger",
                                            _ => "secondary"
                                        }) rounded-pill px-3">@job.Status</span>
                                    </td>
                                    <td class="text-muted">@job.CreatedAt.ToString("dd-MMM-yyyy")</td>
                                    <td class="text-center">
                                        <a asp-action="CandidateMatches" asp-route-jobDemandId="@job.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                            <i class="bi bi-people me-1"></i>Candidates
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@functions {
    string Truncate(string? value, int maxLength)
    {
        if (string.IsNullOrEmpty(value)) return "-";
        return value.Length <= maxLength ? value : value[..maxLength] + "...";
    }
}

@using HumanPlus.Domain.Entities.Employers
@using HumanPlus.Domain.Entities.MasterData
@model Employer
@{
    ViewData["Title"] = "Company Profile";
}

<div class="container py-4">
    <h2><i class="bi bi-building-gear"></i> Company Profile</h2>
    <hr />
    <form asp-action="SaveProfile" method="post">
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Company Name</label>
                <input asp-for="CompanyName" class="form-control" required />
            </div>
            <div class="col-md-6">
                <label class="form-label">Business Type</label>
                <input asp-for="BusinessType" class="form-control" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Industry</label>
                <select asp-for="IndustryId" asp-items='new SelectList(ViewBag.Industries, "Id", "Name")' class="form-select" required>
                    <option value="">-- Select --</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">GST Number</label>
                <input asp-for="GstNumber" class="form-control" />
            </div>
            <div class="col-md-4">
                <label class="form-label">CIN Number</label>
                <input asp-for="CinNumber" class="form-control" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Website</label>
                <input asp-for="Website" class="form-control" />
            </div>
            <div class="col-12">
                <label class="form-label">Office Address</label>
                <textarea asp-for="OfficeAddress" class="form-control" rows="2"></textarea>
            </div>
            <div class="col-md-4">
                <label class="form-label">State</label>
                <select asp-for="StateId" asp-items='new SelectList(ViewBag.States, "Id", "Name")' class="form-select">
                    <option value="">-- Select --</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">District</label>
                <select asp-for="DistrictId" asp-items='new SelectList(ViewBag.Districts, "Id", "Name")' class="form-select">
                    <option value="">-- Select --</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">PIN Code</label>
                <input asp-for="PinCode" class="form-control" />
            </div>
            <hr />
            <h5>Contact Person</h5>
            <div class="col-md-6">
                <label class="form-label">Name</label>
                <input asp-for="ContactPersonName" class="form-control" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Designation</label>
                <input asp-for="ContactPersonDesignation" class="form-control" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Mobile</label>
                <input asp-for="ContactPersonMobile" class="form-control" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Email</label>
                <input asp-for="ContactPersonEmail" class="form-control" type="email" />
            </div>
            <div class="col-12 mt-3">
                <button type="submit" class="btn btn-primary px-4">Save</button>
            </div>
        </div>
    </form>
</div>

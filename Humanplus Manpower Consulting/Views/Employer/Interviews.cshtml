@using HumanPlus.Domain.Entities.Jobs
@model List<Interview>
@{ ViewData["Title"] = "Manage Interviews"; }

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="fw-bold mb-0"><i class="bi bi-calendar-check me-2 text-primary"></i>Manage Interviews</h4>
        <a asp-action="Dashboard" class="btn btn-outline-secondary rounded-pill btn-sm"><i class="bi bi-arrow-left me-1"></i>Back to Dashboard</a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">No interviews scheduled yet.</div>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-3">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 small">
                    <thead class="table-light">
                        <tr>
                            <th class="px-3 py-2">Candidate</th>
                            <th class="py-2">Phone</th>
                            <th class="py-2">Job Demand</th>
                            <th class="py-2">Interview Date</th>
                            <th class="py-2">Location / Link</th>
                            <th class="py-2">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var iv in Model)
                        {
                            <tr>
                                <td class="px-3 fw-medium">@(iv.Candidate?.User?.FullName ?? "N/A")</td>
                                <td>@(iv.Candidate?.User?.PhoneNumber ?? "-")</td>
                                <td>@iv.JobDemand?.JobTitle</td>
                                <td>@iv.InterviewDate.ToString("dd-MMM-yyyy hh:mm tt")</td>
                                <td>@(iv.LocationOrLink ?? "-")</td>
                                <td>
                                    @if (iv.InterviewDate < DateTime.UtcNow)
                                    {
                                        if (iv.IsSelected)
                                        {
                                            <span class="badge bg-success rounded-pill">Selected</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary rounded-pill">Completed</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark rounded-pill">Upcoming</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

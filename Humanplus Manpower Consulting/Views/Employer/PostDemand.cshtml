@using HumanPlus.Domain.Entities.Jobs
@using HumanPlus.Domain.Entities.MasterData
@using HumanPlus.Domain.Enums
@model JobDemand
@{
    ViewData["Title"] = "Post Job Demand";
}

<div class="container py-4">
    <h2><i class="bi bi-plus-circle"></i> Post Manpower Demand</h2>
    <hr />
    <form asp-action="PostDemand" method="post">
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Job Title</label>
                <input asp-for="JobTitle" class="form-control" required />
            </div>
            <div class="col-md-3">
                <label class="form-label">Number of Openings</label>
                <input asp-for="NumberOfOpenings" class="form-control" type="number" required />
            </div>
            <div class="col-md-3">
                <label class="form-label">Required Skills</label>
                <input asp-for="RequiredSkills" class="form-control" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Qualification Required</label>
                <select asp-for="QualificationId" asp-items='new SelectList(ViewBag.Qualifications ?? new List<Qualification>(), "Id", "Name")' class="form-select">
                    <option value="">-- Select --</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Min Experience (Years)</label>
                <input asp-for="MinExperience" class="form-control" type="number" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Max Experience (Years)</label>
                <input asp-for="MaxExperience" class="form-control" type="number" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Min Salary</label>
                <input asp-for="MinSalary" class="form-control" type="number" step="0.01" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Max Salary</label>
                <input asp-for="MaxSalary" class="form-control" type="number" step="0.01" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Gender Preference</label>
                <select asp-for="GenderPreference" asp-items="Html.GetEnumSelectList<Gender>()" class="form-select">
                    <option value="">Any</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Min Age</label>
                <input asp-for="MinAge" class="form-control" type="number" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Max Age</label>
                <input asp-for="MaxAge" class="form-control" type="number" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Duty Hours</label>
                <input asp-for="DutyHours" class="form-control" placeholder="e.g. 8 hours" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Work Location</label>
                <input asp-for="WorkLocation" class="form-control" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Accommodation Details</label>
                <input asp-for="AccommodationDetails" class="form-control" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Food Facility</label>
                <input asp-for="FoodFacility" class="form-control" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Contract Duration (Months)</label>
                <input asp-for="ContractDurationMonths" class="form-control" type="number" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Interview Date</label>
                <input asp-for="InterviewDate" class="form-control" type="date" />
            </div>
            <div class="col-md-3">
                <div class="form-check mt-4">
                    <input asp-for="ImmediateJoining" class="form-check-input" />
                    <label class="form-check-label">Immediate Joining</label>
                </div>
            </div>
            <div class="col-12 mt-3">
                <button type="submit" class="btn btn-primary px-4">Post Demand</button>
            </div>
        </div>
    </form>
</div>

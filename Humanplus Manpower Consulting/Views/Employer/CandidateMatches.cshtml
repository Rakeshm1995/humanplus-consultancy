@using HumanPlus.Domain.Entities.Candidates
@using HumanPlus.Domain.Entities.Jobs
@model List<Candidate>
@{
    ViewData["Title"] = "Candidate Matches";
    var job = ViewBag.JobDemand as JobDemand;
}

<div class="container py-4">
    <h2><i class="bi bi-people"></i> Candidates for @job?.JobTitle</h2>
    <hr />
    <a asp-action="ManageDemands" class="btn btn-outline-secondary mb-3">Back to Demands</a>

    @if (!Model.Any())
    {
        <div class="alert alert-info">No active candidates found.</div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var candidate in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title">@candidate.User?.FullName</h5>
                            <p class="small text-muted">
                                <i class="bi bi-telephone"></i> @candidate.User?.PhoneNumber<br />
                                <i class="bi bi-envelope"></i> @candidate.User?.Email<br />
                                @if (candidate.TotalExperienceYears.HasValue)
                                {
                                    <span><i class="bi bi-briefcase"></i> @candidate.TotalExperienceYears yrs exp</span><br />
                                }
                                <i class="bi bi-geo-alt"></i> @candidate.PreferredLocation
                            </p>
                            @if (!string.IsNullOrEmpty(candidate.PreviousEmployer))
                            {
                                <p class="small">Previous: @candidate.PreviousEmployer</p>
                            }
                            <span class="badge bg-@(candidate.IsProfileComplete ? "success" : "warning")">
                                @(candidate.IsProfileComplete ? "Complete" : "Incomplete")
                            </span>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@model ResetPasswordViewModel
@{ ViewData["Title"] = "Reset Password"; }

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-4">
        <div class="card auth-card shadow border-0 rounded-4">
            <div class="card-body p-4">
                <div class="text-center mb-4">
                    <div class="auth-accent mx-auto mb-3"></div>
                    <h2 class="fw-bold mb-1">Reset Password</h2>
                    <p class="text-muted small">Create a new password for your account</p>
                </div>
                <form asp-action="ResetPassword" method="post" id="resetForm">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="Token" />
                    <input type="hidden" asp-for="Email" />
                    <div class="mb-3">
                        <label asp-for="Password" class="form-label fw-medium">New Password <span class="text-danger">*</span></label>
                        <input asp-for="Password" class="form-control" placeholder="Enter new password (min. 6 characters)" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ConfirmPassword" class="form-label fw-medium">Confirm Password <span class="text-danger">*</span></label>
                        <input asp-for="ConfirmPassword" class="form-control" placeholder="Re-enter your new password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold" id="resetBtn">
                        <span class="spinner-border spinner-border-sm d-none me-2" role="status" id="btnSpinner"></span>
                        <span id="btnText">Reset</span>
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('resetForm')?.addEventListener('submit', function (e) {
            if (!this.checkValidity()) return;
            var btn = document.getElementById('resetBtn');
            btn.disabled = true;
            document.getElementById('btnText').textContent = 'Resetting...';
            document.getElementById('btnSpinner').classList.remove('d-none');
        });
    </script>
}

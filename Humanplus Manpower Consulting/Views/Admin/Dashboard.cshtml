@using HumanPlus.Domain.Entities.Candidates
@model AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
    var adminName = User.Identity!.Name;
}

<div class="container py-4 admin-page">

    @* Welcome Banner *@
    <div class="admin-welcome rounded-4 mb-4 p-4 d-flex align-items-center justify-content-between flex-wrap">
        <div>
            <h1 class="text-white fw-bold mb-1"><i class="bi bi-shield-check me-2"></i>Welcome, @adminName</h1>
            <p class="text-white-50 mb-0">Here's what's happening with HumanPlus today.</p>
        </div>
        <div class="text-end text-white-50 small">
            <div class="fw-medium fs-6">@DateTime.Now.ToString("dddd")</div>
            <div>@DateTime.Now.ToString("dd MMMM yyyy")</div>
        </div>
    </div>

    @* Candidates Section *@
    <div class="section-title-premium">Candidates</div>

    <div class="row g-3 mb-4">
        <div class="col-md-3 col-6">
            <div class="stat-modern">
                <div class="stat-modern-accent bg-accent-teal"></div>
                <div class="stat-modern-body">
                    <div class="stat-modern-icon bg-soft-teal"><i class="bi bi-people-fill text-teal"></i></div>
                    <div class="stat-modern-number text-teal">@Model.TotalJobSeekers</div>
                    <div class="stat-modern-label">Total Job Seekers</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="stat-modern">
                <div class="stat-modern-accent bg-accent-teal"></div>
                <div class="stat-modern-body">
                    <div class="stat-modern-icon bg-soft-teal"><i class="bi bi-person-check-fill text-teal"></i></div>
                    <div class="stat-modern-number text-teal">@Model.ActiveJobSeekers</div>
                    <div class="stat-modern-label">Active Job Seekers</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="stat-modern">
                <div class="stat-modern-accent bg-accent-amber"></div>
                <div class="stat-modern-body">
                    <div class="stat-modern-icon bg-soft-amber"><i class="bi bi-person-plus-fill text-amber"></i></div>
                    <div class="stat-modern-number text-amber">@Model.PendingRegistrations</div>
                    <div class="stat-modern-label">Pending Registrations</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="stat-modern">
                <div class="stat-modern-accent bg-accent-amber"></div>
                <div class="stat-modern-body">
                    <div class="stat-modern-icon bg-soft-amber"><i class="bi bi-clock-fill text-amber"></i></div>
                    <div class="stat-modern-number text-amber">@Model.PendingVerifications</div>
                    <div class="stat-modern-label">Pending Verifications</div>
                </div>
            </div>
        </div>
    </div>

    @* Employers Section *@
    <div class="section-title-premium">Employers</div>

    <div class="row g-3 mb-4">
        <div class="col-md-3 col-6">
            <div class="stat-modern">
                <div class="stat-modern-accent bg-accent-indigo"></div>
                <div class="stat-modern-body">
                    <div class="stat-modern-icon bg-soft-indigo"><i class="bi bi-building-fill text-indigo"></i></div>
                    <div class="stat-modern-number text-indigo">@Model.TotalEmployers</div>
                    <div class="stat-modern-label">Total Employers</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="stat-modern">
                <div class="stat-modern-accent bg-accent-indigo"></div>
                <div class="stat-modern-body">
                    <div class="stat-modern-icon bg-soft-indigo"><i class="bi bi-briefcase-fill text-indigo"></i></div>
                    <div class="stat-modern-number text-indigo">@Model.ActiveEmployers</div>
                    <div class="stat-modern-label">Active Employers</div>
                </div>
            </div>
        </div>
    </div>

    @* Demands & Placements Section *@
    <div class="section-title-premium">Demands &amp; Placements</div>

    <div class="row g-3 mb-4">
        <div class="col-md-3 col-6">
            <div class="stat-modern">
                <div class="stat-modern-accent bg-accent-amber"></div>
                <div class="stat-modern-body">
                    <div class="stat-modern-icon bg-soft-amber"><i class="bi bi-megaphone-fill text-amber"></i></div>
                    <div class="stat-modern-number text-amber">@Model.ActiveDemands</div>
                    <div class="stat-modern-label">Active Demands</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="stat-modern">
                <div class="stat-modern-accent bg-accent-amber"></div>
                <div class="stat-modern-body">
                    <div class="stat-modern-icon bg-soft-amber"><i class="bi bi-hourglass-split text-amber"></i></div>
                    <div class="stat-modern-number text-amber">@Model.PendingDemands</div>
                    <div class="stat-modern-label">Pending Demands</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="stat-modern">
                <div class="stat-modern-accent bg-accent-purple"></div>
                <div class="stat-modern-body">
                    <div class="stat-modern-icon bg-soft-purple"><i class="bi bi-award-fill text-purple"></i></div>
                    <div class="stat-modern-number text-purple">@Model.TotalPlacements</div>
                    <div class="stat-modern-label">Placements</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="stat-modern">
                <div class="stat-modern-accent bg-accent-purple"></div>
                <div class="stat-modern-body">
                    <div class="stat-modern-icon bg-soft-purple"><i class="bi bi-calendar-event-fill text-purple"></i></div>
                    <div class="stat-modern-number text-purple">@Model.UpcomingInterviews</div>
                    <div class="stat-modern-label">Upcoming Interviews</div>
                </div>
            </div>
        </div>
    </div>

    @* Revenue Section *@
    <div class="section-title-premium">Revenue</div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="stat-modern">
                <div class="stat-modern-accent bg-accent-teal"></div>
                <div class="stat-modern-body">
                    <div class="stat-modern-icon bg-soft-teal"><i class="bi bi-wallet2 text-teal"></i></div>
                    <div class="stat-modern-number text-teal">₹ @Model.TotalFeesCollected.ToString("N0")</div>
                    <div class="stat-modern-label">Total Fees Collected</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-modern">
                <div class="stat-modern-accent bg-accent-amber"></div>
                <div class="stat-modern-body">
                    <div class="stat-modern-icon bg-soft-amber"><i class="bi bi-hourglass-split text-amber"></i></div>
                    <div class="stat-modern-number text-amber">@Model.PendingFeeCount</div>
                    <div class="stat-modern-label">Pending Fee Payments</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-modern">
                <div class="stat-modern-accent bg-accent-purple"></div>
                <div class="stat-modern-body">
                    <div class="stat-modern-icon bg-soft-purple"><i class="bi bi-piggy-bank-fill text-purple"></i></div>
                    <div class="stat-modern-number text-purple">₹ @Model.TotalCommission.ToString("N0")</div>
                    <div class="stat-modern-label">Total Commission</div>
                </div>
            </div>
        </div>
    </div>

    @* Quick Actions *@
    <div class="section-title-premium">Quick Actions</div>

    <div class="row g-3 mb-4">
        <div class="col-6 col-md-4 col-lg-2">
            <a asp-action="Candidates" class="text-decoration-none d-block">
                <div class="action-card-premium bg-soft-grad-teal">
                    <div class="action-icon"><i class="bi bi-people-fill text-accent-teal"></i></div>
                    <div class="action-title">Candidates</div>
                    <div class="action-subtitle">Manage</div>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-4 col-lg-2">
            <a asp-action="Employers" class="text-decoration-none d-block">
                <div class="action-card-premium bg-soft-grad-indigo">
                    <div class="action-icon"><i class="bi bi-building-fill text-accent-indigo"></i></div>
                    <div class="action-title">Employers</div>
                    <div class="action-subtitle">Manage</div>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-4 col-lg-2">
            <a asp-action="JobDemands" class="text-decoration-none d-block">
                <div class="action-card-premium bg-soft-grad-amber">
                    <div class="action-icon"><i class="bi bi-briefcase-fill text-accent-amber"></i></div>
                    <div class="action-title">Job Demands</div>
                    <div class="action-subtitle">Manage</div>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-4 col-lg-2">
            <a asp-action="MasterData" class="text-decoration-none d-block">
                <div class="action-card-premium bg-soft-grad-blue">
                    <div class="action-icon"><i class="bi bi-gear-fill text-accent-blue"></i></div>
                    <div class="action-title">Master Data</div>
                    <div class="action-subtitle">Settings</div>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-4 col-lg-2">
            <a asp-action="Reports" class="text-decoration-none d-block">
                <div class="action-card-premium bg-soft-grad-purple">
                    <div class="action-icon"><i class="bi bi-bar-chart-fill text-accent-purple"></i></div>
                    <div class="action-title">Reports</div>
                    <div class="action-subtitle">View</div>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-4 col-lg-2">
            <a asp-action="AuditLogs" class="text-decoration-none d-block">
                <div class="action-card-premium bg-soft-grad-rose">
                    <div class="action-icon"><i class="bi bi-journal-text-fill text-accent-rose"></i></div>
                    <div class="action-title">Audit Logs</div>
                    <div class="action-subtitle">View Logs</div>
                </div>
            </a>
        </div>
    </div>

    @* Monthly Registrations + Sector-wise Statistics *@
    <div class="row g-4 mb-4">
        <div class="col-md-7">
            <div class="dashboard-card h-100">
                <div class="card-head bg-soft-grad-teal text-accent-teal">
                    <i class="bi bi-graph-up-arrow"></i> Monthly Registrations <span class="small opacity-75 fw-normal">(Last 12 Months)</span>
                </div>
                <div class="p-3">
                    <canvas id="registrationsChart" height="250"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-5">
            <div class="dashboard-card h-100">
                <div class="card-head bg-soft-grad-purple text-accent-purple">
                    <i class="bi bi-pie-chart-fill"></i> Sector-wise Statistics
                </div>
                <div>
                    @if (Model.SectorStats.Any())
                    {
                        <div class="table-responsive" style="max-height:320px;">
                            <table class="sector-table table mb-0 align-middle">
                                <thead>
                                    <tr>
                                        <th>Sector</th>
                                        <th class="text-center">Candidates</th>
                                        <th class="text-center">Employers</th>
                                        <th class="text-center">Total</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var s in Model.SectorStats)
                                    {
                                        <tr>
                                            <td class="fw-medium">@s.IndustryName</td>
                                            <td class="text-center"><span class="sector-badge teal">@s.CandidateCount</span></td>
                                            <td class="text-center"><span class="sector-badge indigo">@s.EmployerCount</span></td>
                                            <td class="text-center fw-bold" style="color:#111827;">@(s.CandidateCount + s.EmployerCount)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4 text-muted"><i class="bi bi-inbox me-2"></i>No sector data yet</div>
                    }
                </div>
            </div>
        </div>
    </div>

    @* Recent Registrations *@
    <div class="row g-4">
        <div class="col-md-6">
            <div class="dashboard-card h-100">
                <div class="card-head bg-soft-grad-teal text-accent-teal d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-person-plus-fill"></i> Recent Candidates</span>
                    <a asp-action="Candidates" class="btn btn-sm rounded-pill px-3 fw-medium" style="background:rgba(255,255,255,0.85);color:#0e7490;">View All <i class="bi bi-arrow-right ms-1"></i></a>
                </div>
                <div>
                    @if (Model.RecentCandidates.Count > 0)
                    {
                        @foreach (var c in Model.RecentCandidates)
                        {
                            <div class="recent-item">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="avatar-squircle teal-bg"><i class="bi bi-person"></i></div>
                                    <div>
                                        <div class="item-name">@c.User?.FullName</div>
                                        <div class="item-date">@c.CreatedAt.ToString("dd MMM yyyy")</div>
                                    </div>
                                </div>
                                <span class="badge rounded-pill px-3 py-2 fw-medium" style="background:@(c.Status == HumanPlus.Domain.Enums.CandidateStatus.Active ? "rgba(5,150,105,0.12)" : c.Status == HumanPlus.Domain.Enums.CandidateStatus.PendingVerification ? "rgba(217,119,6,0.12)" : "rgba(107,114,128,0.12)");color:@(c.Status == HumanPlus.Domain.Enums.CandidateStatus.Active ? "#059669" : c.Status == HumanPlus.Domain.Enums.CandidateStatus.PendingVerification ? "#d97706" : "#6b7280");">
                                    @c.Status
                                </span>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-4 text-muted"><i class="bi bi-inbox me-2"></i>No candidates yet</div>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="dashboard-card h-100">
                <div class="card-head bg-soft-grad-indigo text-accent-indigo d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-building-add-fill"></i> Recent Employers</span>
                    <a asp-action="Employers" class="btn btn-sm rounded-pill px-3 fw-medium" style="background:rgba(255,255,255,0.85);color:#4338ca;">View All <i class="bi bi-arrow-right ms-1"></i></a>
                </div>
                <div>
                    @if (Model.RecentEmployers.Count > 0)
                    {
                        @foreach (var e in Model.RecentEmployers)
                        {
                            <div class="recent-item">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="avatar-squircle indigo-bg"><i class="bi bi-building"></i></div>
                                    <div>
                                        <div class="item-name">@e.CompanyName</div>
                                        <div class="item-date">@e.CreatedAt.ToString("dd MMM yyyy")</div>
                                    </div>
                                </div>
                                <span class="badge rounded-pill px-3 py-2 fw-medium" style="background:@(e.Status == HumanPlus.Domain.Enums.EmployerStatus.Active ? "rgba(5,150,105,0.12)" : e.Status == HumanPlus.Domain.Enums.EmployerStatus.PendingVerification ? "rgba(217,119,6,0.12)" : "rgba(107,114,128,0.12)");color:@(e.Status == HumanPlus.Domain.Enums.EmployerStatus.Active ? "#059669" : e.Status == HumanPlus.Domain.Enums.EmployerStatus.PendingVerification ? "#d97706" : "#6b7280");">
                                    @e.Status
                                </span>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-4 text-muted"><i class="bi bi-inbox me-2"></i>No employers yet</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
    <script>
        (function () {
            var months = @Html.Raw(Json.Serialize(Model.MonthlyRegistrations.Select(m => m.Month)));
            var candidates = @Html.Raw(Json.Serialize(Model.MonthlyRegistrations.Select(m => m.CandidateCount)));
            var employers = @Html.Raw(Json.Serialize(Model.MonthlyRegistrations.Select(m => m.EmployerCount)));

            var ctx = document.getElementById('registrationsChart').getContext('2d');

            var tealGrad = ctx.createLinearGradient(0, 0, 0, 250);
            tealGrad.addColorStop(0, 'rgba(13, 148, 136, 0.65)');
            tealGrad.addColorStop(1, 'rgba(13, 148, 136, 0.08)');

            var purpleGrad = ctx.createLinearGradient(0, 0, 0, 250);
            purpleGrad.addColorStop(0, 'rgba(124, 58, 237, 0.65)');
            purpleGrad.addColorStop(1, 'rgba(124, 58, 237, 0.08)');

            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: months,
                    datasets: [
                        {
                            label: 'Job Seekers',
                            data: candidates,
                            backgroundColor: tealGrad,
                            borderColor: 'rgba(13, 148, 136, 0.6)',
                            borderWidth: 1,
                            borderRadius: 6,
                            borderSkipped: false
                        },
                        {
                            label: 'Employers',
                            data: employers,
                            backgroundColor: purpleGrad,
                            borderColor: 'rgba(124, 58, 237, 0.6)',
                            borderWidth: 1,
                            borderRadius: 6,
                            borderSkipped: false
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'top',
                            align: 'end',
                            labels: {
                                boxWidth: 10,
                                boxHeight: 10,
                                borderRadius: 3,
                                padding: 16,
                                usePointStyle: true,
                                pointStyle: 'rectRounded',
                                font: { size: 12, weight: '500' }
                            }
                        },
                        tooltip: {
                            backgroundColor: '#1f2937',
                            titleFont: { size: 12, weight: '600' },
                            bodyFont: { size: 12 },
                            cornerRadius: 8,
                            padding: 10,
                            displayColors: true
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                stepSize: 1,
                                font: { size: 11 },
                                color: '#9ca3af'
                            },
                            grid: {
                                color: 'rgba(0,0,0,0.04)',
                                drawBorder: false
                            }
                        },
                        x: {
                            ticks: {
                                font: { size: 10 },
                                color: '#9ca3af',
                                maxRotation: 45
                            },
                            grid: { display: false }
                        }
                    },
                    animation: {
                        duration: 800,
                        easing: 'easeOutQuart'
                    }
                }
            });
        })();
    </script>
}

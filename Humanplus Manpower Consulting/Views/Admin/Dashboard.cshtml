@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container py-4">
    <h2><i class="bi bi-speedometer2"></i> Executive Dashboard</h2>
    <hr />
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card text-center p-3 border-primary shadow-sm">
                <h6>Total Candidates</h6>
                <span class="display-6 text-primary">@ViewBag.TotalCandidates</span>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center p-3 border-success shadow-sm">
                <h6>Active Candidates</h6>
                <span class="display-6 text-success">@ViewBag.ActiveCandidates</span>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center p-3 border-warning shadow-sm">
                <h6>Pending Verification</h6>
                <span class="display-6 text-warning">@ViewBag.PendingCandidates</span>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center p-3 border-info shadow-sm">
                <h6>Total Employers</h6>
                <span class="display-6 text-info">@ViewBag.TotalEmployers</span>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center p-3 border-success shadow-sm">
                <h6>Active Employers</h6>
                <span class="display-6 text-success">@ViewBag.ActiveEmployers</span>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center p-3 border-primary shadow-sm">
                <h6>Active Demands</h6>
                <span class="display-6 text-primary">@ViewBag.ActiveDemands</span>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center p-3 border-warning shadow-sm">
                <h6>Pending Demands</h6>
                <span class="display-6 text-warning">@ViewBag.PendingDemands</span>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center p-3 border-info shadow-sm">
                <h6>Total Placements</h6>
                <span class="display-6 text-info">@ViewBag.TotalPlacements</span>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <i class="bi bi-people display-6 text-primary"></i>
                    <h5 class="mt-2">Candidates</h5>
                    <a asp-action="Candidates" class="btn btn-outline-primary">Manage</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <i class="bi bi-building display-6 text-primary"></i>
                    <h5 class="mt-2">Employers</h5>
                    <a asp-action="Employers" class="btn btn-outline-primary">Manage</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <i class="bi bi-briefcase display-6 text-primary"></i>
                    <h5 class="mt-2">Job Demands</h5>
                    <a asp-action="JobDemands" class="btn btn-outline-primary">Manage</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <i class="bi bi-gear display-6 text-primary"></i>
                    <h5 class="mt-2">Master Data</h5>
                    <a asp-action="MasterData" class="btn btn-outline-primary">Settings</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <i class="bi bi-file-earmark-bar-graph display-6 text-primary"></i>
                    <h5 class="mt-2">Reports</h5>
                    <a asp-action="Reports" class="btn btn-outline-primary">View Reports</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <i class="bi bi-journal-text display-6 text-primary"></i>
                    <h5 class="mt-2">Audit Logs</h5>
                    <a asp-action="AuditLogs" class="btn btn-outline-primary">View Logs</a>
                </div>
            </div>
        </div>
    </div>
</div>

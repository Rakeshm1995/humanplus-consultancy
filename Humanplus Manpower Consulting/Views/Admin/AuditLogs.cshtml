@using HumanPlus.Domain.Entities.System
@model List<AuditLog>
@{
    ViewData["Title"] = "Audit Logs";
}

<div class="container py-4">
    <h2><i class="bi bi-journal-text"></i> Audit Logs</h2>
    <hr />
    @if (!Model.Any())
    {
        <p class="text-muted">No audit logs yet.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Time</th>
                        <th>User ID</th>
                        <th>Action</th>
                        <th>Entity</th>
                        <th>Details</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in Model)
                    {
                        <tr>
                            <td>@log.CreatedAt.ToString("dd-MMM-yy HH:mm")</td>
                            <td class="small">@log.UserId</td>
                            <td>@log.Action</td>
                            <td>@log.EntityType</td>
                            <td class="small">@log.Details</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@using HumanPlus.Domain.Entities.Jobs
@using HumanPlus.Domain.Enums
@model List<JobDemand>
@{
    ViewData["Title"] = "Manage Job Demands";
}

<div class="container py-4">
    <h2><i class="bi bi-briefcase"></i> Job Demand Management</h2>
    <hr />

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    <form method="get" class="row g-2 mb-3">
        <div class="col-md-3">
            <select name="status" class="form-select" onchange="this.form.submit()">
                <option value="">All Statuses</option>
                @foreach (var s in (JobDemandStatus[])ViewBag.JobDemandStatuses)
                {
                    <option value="@s" selected="@(ViewBag.SelectedStatus == s.ToString())">@s</option>
                }
            </select>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-hover">
            <thead class="table-light">
                <tr>
                    <th>Job Title</th>
                    <th>Employer</th>
                    <th>Openings</th>
                    <th>Location</th>
                    <th>Status</th>
                    <th>Posted</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var j in Model)
                {
                    <tr>
                        <td>@j.JobTitle</td>
                        <td>@j.Employer?.CompanyName</td>
                        <td>@j.NumberOfOpenings</td>
                        <td>@j.WorkLocation</td>
                        <td>
                            <span class="badge bg-@(j.Status switch {
                                JobDemandStatus.Approved => "success",
                                JobDemandStatus.PendingApproval => "warning",
                                JobDemandStatus.Fulfilled => "info",
                                JobDemandStatus.Closed => "secondary",
                                JobDemandStatus.Cancelled => "danger",
                                _ => "primary"
                            })">@j.Status</span>
                        </td>
                        <td>@j.CreatedAt.ToString("dd-MMM-yy")</td>
                        <td>
                            <form asp-action="UpdateDemandStatus" method="post" class="d-inline">
                                <input type="hidden" name="jobDemandId" value="@j.Id" />
                                <select name="newStatus" class="form-select form-select-sm d-inline w-auto" onchange="this.form.submit()">
                                    @foreach (var s in (JobDemandStatus[])ViewBag.JobDemandStatuses)
                                    {
                                        <option value="@s" selected="@(j.Status == s)">@s</option>
                                    }
                                </select>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

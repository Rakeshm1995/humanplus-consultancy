@using HumanPlus.Domain.Entities.Jobs
@using HumanPlus.Domain.Enums
@model List<JobDemand>
@{
    ViewData["Title"] = "Manage Job Demands";
}

<div class="container-fluid px-4 py-4">

    <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
            <h4 class="fw-bold mb-1"><i class="bi bi-briefcase me-2 text-indigo"></i>Job Demand Management</h4>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb small mb-0">
                    <li class="breadcrumb-item"><a asp-action="Dashboard" class="text-decoration-none">Dashboard</a></li>
                    <li class="breadcrumb-item active">Job Demands</li>
                </ol>
            </nav>
        </div>
        <a asp-action="JobDemands" class="btn btn-outline-indigo rounded-pill btn-sm"><i class="bi bi-arrow-clockwise me-1"></i>Refresh</a>
    </div>

    <form method="get" class="row g-2 mb-3 align-items-end">
        <div class="col-md-3">
            <select name="status" class="form-select form-select-sm" onchange="this.form.submit()">
                <option value="">All Statuses</option>
                @foreach (var s in (JobDemandStatus[])ViewBag.JobDemandStatuses)
                {
                    <option value="@s" selected="@(ViewBag.SelectedStatus == s.ToString())">@s</option>
                }
            </select>
        </div>
    </form>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">
            <div class="candidates-table-wrap">
                <table class="table table-hover align-middle mb-0 small">
                    <thead class="table-light">
                        <tr>
                            <th class="px-3 py-3">Job Title</th>
                            <th class="py-3">Employer</th>
                            <th class="py-3">Openings</th>
                            <th class="py-3">Location</th>
                            <th class="py-3">Status</th>
                            <th class="py-3">Posted</th>
                            <th class="text-center py-3">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var j in Model)
                        {
                            <tr>
                                <td class="px-3 fw-medium">@j.JobTitle</td>
                                <td>@(j.Employer?.CompanyName ?? "-")</td>
                                <td>@j.NumberOfOpenings</td>
                                <td>@(j.WorkLocation ?? "-")</td>
                                <td>
                                    <span class="badge bg-@(j.Status switch {
                                        JobDemandStatus.Approved => "success",
                                        JobDemandStatus.PendingApproval => "warning text-dark",
                                        JobDemandStatus.Fulfilled => "info",
                                        JobDemandStatus.Closed => "secondary",
                                        JobDemandStatus.Cancelled => "danger",
                                        JobDemandStatus.CandidatesAssigned => "primary",
                                        JobDemandStatus.InterviewScheduled => "indigo",
                                        _ => "secondary"
                                    }) rounded-pill px-3">@j.Status</span>
                                </td>
                                <td class="text-muted">@j.CreatedAt.ToString("dd-MMM-yy")</td>
                                <td class="text-center">
                                    <div class="dropdown d-inline">
                                        <button class="btn btn-sm btn-outline-secondary rounded-pill px-2 py-0 dropdown-toggle" type="button" data-bs-toggle="dropdown" data-bs-boundary="viewport" title="Change Status">
                                            <i class="bi bi-arrow-repeat"></i>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end small py-1" style="min-width:160px;max-height:250px;overflow-y:auto;">
                                            @foreach (var s in (JobDemandStatus[])ViewBag.JobDemandStatuses)
                                            {
                                                <li>
                                                    <form asp-action="UpdateDemandStatus" method="post" class="d-inline">
                                                        <input type="hidden" name="jobDemandId" value="@j.Id" />
                                                        <input type="hidden" name="newStatus" value="@s" />
                                                        <button type="submit" class="dropdown-item py-1 @(j.Status == s ? "active" : "")" data-confirm="Change status to @(s)?">@s</button>
                                                    </form>
                                                </li>
                                            }
                                        </ul>
                                    </div>
                                </td>
                                <td class="text-center text-nowrap">
                                    <a asp-action="MatchCandidates" asp-route-jobDemandId="@j.Id" class="btn btn-sm btn-outline-teal rounded-pill px-2 py-0 me-1" title="Match Candidates"><i class="bi bi-people"></i></a>
                                    <button type="button" class="btn btn-sm btn-outline-indigo rounded-pill px-2 py-0 me-1 recruiters-btn" data-demand-id="@j.Id" data-title="@j.JobTitle" title="Assign Recruiters"><i class="bi bi-person-badge"></i></button>
                                    <a asp-action="ScheduleInterview" asp-route-jobDemandId="@j.Id" class="btn btn-sm btn-outline-amber rounded-pill px-2 py-0 me-1" title="Schedule Interview"><i class="bi bi-calendar-plus"></i></a>
                                    <a asp-action="Interviews" asp-route-jobDemandId="@j.Id" class="btn btn-sm btn-outline-info rounded-pill px-2 py-0" title="View Interviews"><i class="bi bi-calendar-event"></i></a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (!Model.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                    <span>No job demands found</span>
                </div>
            }
        </div>
    </div>
</div>

@* Confirmation Modal *@
<div class="modal fade" id="confirmModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-warning text-dark border-0">
                <h6 class="modal-title"><i class="bi bi-exclamation-triangle me-2"></i>Confirm Action</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center py-3" id="confirmMessage"></div>
            <div class="modal-footer border-0 justify-content-center">
                <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-warning rounded-pill px-4" id="confirmBtn">Yes, Confirm</button>
            </div>
        </div>
    </div>
</div>

@* Success / Error Modals *@
@if (TempData["Success"] != null)
{
    <div class="modal fade" id="successModal" tabindex="-1" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-success text-white border-0">
                    <h6 class="modal-title"><i class="bi bi-check-circle-fill me-2"></i>Success</h6>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body text-center py-3">
                    <i class="bi bi-check-circle text-success display-4 mb-2 d-block"></i>
                    <p class="mb-0">@TempData["Success"]</p>
                </div>
                <div class="modal-footer border-0 justify-content-center pt-0">
                    <button type="button" class="btn btn-success rounded-pill px-4" data-bs-dismiss="modal">OK</button>
                </div>
            </div>
        </div>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="modal fade" id="errorModal" tabindex="-1" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-danger text-white border-0">
                    <h6 class="modal-title"><i class="bi bi-exclamation-circle-fill me-2"></i>Error</h6>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body text-center py-3">
                    <i class="bi bi-exclamation-circle text-danger display-4 mb-2 d-block"></i>
                    <p class="mb-0">@TempData["Error"]</p>
                </div>
                <div class="modal-footer border-0 justify-content-center pt-0">
                    <button type="button" class="btn btn-danger rounded-pill px-4" data-bs-dismiss="modal">OK</button>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        var pendingForm = null;
        document.querySelectorAll('[data-confirm]').forEach(function (el) {
            el.addEventListener('click', function (e) {
                e.preventDefault();
                pendingForm = this.closest('form');
                document.getElementById('confirmMessage').innerHTML = '<p class="mb-0 fw-medium">' + this.dataset.confirm + '</p>';
                new bootstrap.Modal(document.getElementById('confirmModal')).show();
            });
        });
        document.getElementById('confirmBtn').addEventListener('click', function () {
            if (pendingForm) pendingForm.submit();
        });

        @if (TempData["Success"] != null)
        {
            <text>
            document.addEventListener('DOMContentLoaded', function () {
                new bootstrap.Modal(document.getElementById('successModal')).show();
            });
            </text>
        }
        @if (TempData["Error"] != null)
        {
            <text>
            document.addEventListener('DOMContentLoaded', function () {
                new bootstrap.Modal(document.getElementById('errorModal')).show();
            });
            </text>
        }
    </script>

    @* Recruiters Modal *@
    <div class="modal fade" id="recruitersModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow" id="recruitersModalContent">
                <div class="text-center py-5"><div class="spinner-border text-indigo" role="status"></div><p class="mt-2 text-muted small">Loading...</p></div>
            </div>
        </div>
    </div>

    <script>
        document.querySelectorAll('.recruiters-btn').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var demandId = this.dataset.demandId;
                var modal = new bootstrap.Modal(document.getElementById('recruitersModal'));
                document.getElementById('recruitersModalContent').innerHTML = '<div class="text-center py-5"><div class="spinner-border text-indigo" role="status"></div><p class="mt-2 text-muted small">Loading...</p></div>';
                modal.show();
                fetch('/Admin/JobDemandRecruiters?jobDemandId=' + demandId)
                    .then(function (r) { return r.text(); })
                    .then(function (html) {
                        document.getElementById('recruitersModalContent').innerHTML = html;
                    })
                    .catch(function () {
                        document.getElementById('recruitersModalContent').innerHTML = '<div class="p-4 text-center text-danger">Error loading recruiters.</div>';
                    });
            });
        });
    </script>
}



@using HumanPlus.Domain.Entities.System
@using HumanPlus.Domain.Entities.Employers
@model List<AuditLog>
@{
    var employer = ViewBag.Employer as Employer;
}

<div class="modal fade" id="employerActivitiesModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-info text-white border-0">
                <h6 class="modal-title"><i class="bi bi-activity me-2"></i>Activities - @(employer?.CompanyName ?? "Employer")</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-3">
                @if (Model.Any())
                {
                    <table class="table table-hover align-middle mb-0 small">
                        <thead class="table-light">
                            <tr>
                                <th class="px-2">Date</th>
                                <th>Action</th>
                                <th>Details</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in Model)
                            {
                                <tr>
                                    <td class="px-2 text-nowrap small">@log.CreatedAt.ToString("dd-MMM-yyyy HH:mm")</td>
                                    <td><span class="badge bg-secondary rounded-pill">@log.Action</span></td>
                                    <td class="small">@(log.Details ?? "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted text-center mb-0 py-3">No activities recorded yet.</p>
                }
            </div>
            <div class="modal-footer border-0 justify-content-center pt-0 pb-3">
                <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>
@using HumanPlus.Domain.Entities.Candidates
@model Candidate

<div class="modal-header bg-teal text-white border-0">
    <h6 class="modal-title"><i class="bi bi-file-earmark-text me-2"></i>Documents — @Model.User?.FullName</h6>
    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
</div>
<div class="modal-body">
    @if (Model.Documents.Any())
    {
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Type</th>
                        <th>File Name</th>
                        <th>Uploaded</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var doc in Model.Documents.OrderByDescending(d => d.UploadedAt))
                    {
                        <tr>
                            <td><span class="badge bg-secondary-subtle text-secondary px-3">@doc.DocumentType</span></td>
                            <td><a href="@doc.FilePath" target="_blank" class="text-decoration-none small">@doc.OriginalFileName</a></td>
                            <td class="small">@doc.UploadedAt.ToString("dd-MMM-yyyy")</td>
                            <td>
                                @if (doc.IsVerified)
                                {
                                    <span class="badge bg-success-subtle text-success"><i class="bi bi-check-circle me-1"></i>Verified</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning-subtle text-warning">Pending</span>
                                }
                            </td>
                            <td>
                                @if (!doc.IsVerified)
                                {
                                    <form method="post" asp-action="VerifyDocument" asp-route-documentId="@doc.Id" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-outline-success" data-confirm="Verify this document?">
                                            <i class="bi bi-check-lg me-1"></i>Verify
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-success small"><i class="bi bi-check-circle-fill me-1"></i>Done</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-4 text-muted">
            <i class="bi bi-inbox fs-2 d-block mb-2"></i>
            No documents uploaded yet
        </div>
    }
</div>
<div class="modal-footer border-0">
    <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Close</button>
</div>

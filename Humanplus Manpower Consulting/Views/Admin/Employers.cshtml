@using HumanPlus.Domain.Entities.Employers
@using HumanPlus.Domain.Enums
@model List<Employer>
@{
    ViewData["Title"] = "Employer Management";
}

<div class="container-fluid px-4 py-4">

    <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
            <h4 class="fw-bold mb-1"><i class="bi bi-building me-2 text-teal"></i>Employer Management</h4>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb small mb-0">
                    <li class="breadcrumb-item"><a asp-action="Dashboard" class="text-decoration-none">Dashboard</a></li>
                    <li class="breadcrumb-item active">Employers</li>
                </ol>
            </nav>
        </div>
        <a asp-action="Employers" class="btn btn-outline-teal rounded-pill btn-sm"><i class="bi bi-arrow-clockwise me-1"></i>Refresh</a>
    </div>

    @* Search / Filter *@
    <form method="get" class="row g-2 mb-3 align-items-end">
        <div class="col-md-3">
            <select name="status" class="form-select form-select-sm" onchange="this.form.submit()">
                <option value="">All Statuses</option>
                @foreach (var s in (EmployerStatus[])ViewBag.EmployerStatuses)
                {
                    <option value="@s" selected="@(ViewBag.SelectedStatus == s.ToString())">@s</option>
                }
            </select>
        </div>
        <div class="col-md-5">
            <input type="text" name="search" class="form-control form-control-sm" placeholder="Search company name, email..." value="@ViewBag.Search" />
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary btn-sm w-100"><i class="bi bi-search me-1"></i>Search</button>
        </div>
    </form>

    @* Table *@
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">
            <div class="candidates-table-wrap">
                <table class="table table-hover align-middle mb-0 small">
                    <thead class="table-light">
                        <tr>
                            <th class="px-3 py-3">Company</th>
                            <th class="py-3">Contact Person</th>
                            <th class="py-3">Email</th>
                            <th class="py-3">Industry</th>
                            <th class="py-3">Status</th>
                            <th class="py-3">Registered</th>
                            <th class="py-3">Subscription</th>
                            <th class="text-center py-3" style="min-width:200px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var e in Model)
                        {
                            <tr>
                                <td class="px-3 fw-medium">@e.CompanyName</td>
                                <td>@e.ContactPersonName</td>
                                <td>@e.User?.Email</td>
                                <td>@(e.Industry?.Name ?? "-")</td>
                                <td>
                                    <span class="badge bg-@(e.Status switch {
                                        EmployerStatus.Active => "success",
                                        EmployerStatus.PendingVerification => "warning text-dark",
                                        EmployerStatus.Suspended => "danger",
                                        EmployerStatus.Inactive => "secondary",
                                        _ => "secondary"
                                    }) rounded-pill px-3">@e.Status</span>
                                </td>
                                <td class="text-muted">@e.CreatedAt.ToString("dd-MMM-yy")</td>
                                <td>
                                    @{
                                        var sub = e.Subscriptions?.OrderByDescending(s => s.EndDate).FirstOrDefault();
                                    }
                                    @if (sub != null)
                                    {
                                        <span class="small @(sub.IsPaid ? "text-success" : "text-warning")">
                                            @sub.StartDate.ToString("dd-MMM-yy") - @sub.EndDate.ToString("dd-MMM-yy")
                                            @if (sub.IsPaid) { <i class="bi bi-check-circle-fill text-success ms-1 small"></i> }
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">None</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="btn-group btn-group-sm" role="group">
                                        @* Approve *@
                                        @if (e.Status == EmployerStatus.PendingVerification)
                                        {
                                            <form asp-action="ApproveEmployer" method="post" class="d-inline">
                                                <input type="hidden" name="employerId" value="@e.Id" />
                                                <button type="submit" class="btn btn-outline-success rounded-pill px-2 py-0 me-1" title="Approve" data-confirm="Approve @(e.CompanyName)?"><i class="bi bi-check-lg"></i></button>
                                            </form>
                                        }
                                        @* Documents *@
                                        <button type="button" class="btn btn-outline-info rounded-pill px-2 py-0 me-1 btn-view-docs" data-employer-id="@e.Id" title="Documents"><i class="bi bi-file-earmark"></i></button>
                                        @* Subscription *@
                                        <a asp-action="ManageSubscription" asp-route-employerId="@e.Id" class="btn btn-outline-primary rounded-pill px-2 py-0 me-1" title="Subscription"><i class="bi bi-credit-card"></i></a>
                                        @* Activities *@
                                        <button type="button" class="btn btn-outline-secondary rounded-pill px-2 py-0 me-1 btn-view-activities" data-employer-id="@e.Id" title="Activities"><i class="bi bi-activity"></i></button>
                                        @* Communication *@
                                        <button type="button" class="btn btn-outline-primary rounded-pill px-2 py-0 me-1 btn-communicate" data-employer-id="@e.Id" title="Send Email/SMS"><i class="bi bi-chat-dots"></i></button>
                                        @* Status Change *@
                                        <div class="dropdown d-inline">
                                            <button class="btn btn-outline-secondary rounded-pill px-2 py-0 dropdown-toggle" type="button" data-bs-toggle="dropdown" data-bs-boundary="viewport" title="Change Status">
                                                <i class="bi bi-arrow-repeat"></i>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end small py-1" style="min-width:140px;max-height:250px;overflow-y:auto;">
                                                @foreach (var s in (EmployerStatus[])ViewBag.EmployerStatuses)
                                                {
                                                    <li>
                                                        <form asp-action="UpdateEmployerStatus" method="post" class="d-inline">
                                                            <input type="hidden" name="employerId" value="@e.Id" />
                                                            <input type="hidden" name="newStatus" value="@s" />
                                                            <button type="submit" class="dropdown-item py-1 @(e.Status == s ? "active" : "")" data-confirm="Change status to @(s)?">@s</button>
                                                        </form>
                                                    </li>
                                                }
                                            </ul>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (!Model.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                    <span>No employers found</span>
                </div>
            }
        </div>
    </div>
</div>

@* Communication Modal *@
<div class="modal fade" id="commModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white border-0">
                <h6 class="modal-title"><i class="bi bi-chat-dots me-2"></i>Send Communication</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <ul class="nav nav-tabs mb-3" id="commTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active small" id="email-tab" data-bs-toggle="tab" data-bs-target="#emailPane" type="button" role="tab"><i class="bi bi-envelope me-1"></i>Email</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link small" id="sms-tab" data-bs-toggle="tab" data-bs-target="#smsPane" type="button" role="tab"><i class="bi bi-chat me-1"></i>SMS</button>
                    </li>
                </ul>
                <div class="tab-content">
                    <div class="tab-pane fade show active" id="emailPane" role="tabpanel">
                        <form asp-action="SendEmployerEmail" method="post" id="emailForm">
                            <input type="hidden" name="employerId" id="emailEmployerId" />
                            <div class="mb-2">
                                <label class="form-label small">Subject</label>
                                <input name="subject" class="form-control form-control-sm" required />
                            </div>
                            <div class="mb-2">
                                <label class="form-label small">Message</label>
                                <textarea name="body" class="form-control form-control-sm" rows="4" required></textarea>
                            </div>
                            <button type="submit" class="btn btn-primary btn-sm rounded-pill px-4"><i class="bi bi-send me-1"></i>Send Email</button>
                        </form>
                    </div>
                    <div class="tab-pane fade" id="smsPane" role="tabpanel">
                        <form asp-action="SendEmployerSms" method="post" id="smsForm">
                            <input type="hidden" name="employerId" id="smsEmployerId" />
                            <div class="mb-2">
                                <label class="form-label small">Message</label>
                                <textarea name="message" class="form-control form-control-sm" rows="4" required></textarea>
                            </div>
                            <button type="submit" class="btn btn-info btn-sm rounded-pill px-4 text-white"><i class="bi bi-send me-1"></i>Send SMS</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@* Confirmation Modal *@
<div class="modal fade" id="confirmModal" tabindex="-1" style="z-index: 9999;">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-warning text-dark border-0">
                <h6 class="modal-title"><i class="bi bi-exclamation-triangle me-2"></i>Confirm Action</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center py-3" id="confirmMessage"></div>
            <div class="modal-footer border-0 justify-content-center">
                <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-warning rounded-pill px-4" id="confirmBtn">Yes, Confirm</button>
            </div>
        </div>
    </div>
</div>

@* Success / Error Modals *@
@if (TempData["Success"] != null)
{
    <div class="modal fade" id="successModal" tabindex="-1" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-success text-white border-0">
                    <h6 class="modal-title"><i class="bi bi-check-circle-fill me-2"></i>Success</h6>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body text-center py-3">
                    <i class="bi bi-check-circle text-success display-4 mb-2 d-block"></i>
                    <p class="mb-0">@TempData["Success"]</p>
                </div>
                <div class="modal-footer border-0 justify-content-center pt-0">
                    <button type="button" class="btn btn-success rounded-pill px-4" data-bs-dismiss="modal">OK</button>
                </div>
            </div>
        </div>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="modal fade" id="errorModal" tabindex="-1" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-danger text-white border-0">
                    <h6 class="modal-title"><i class="bi bi-exclamation-circle-fill me-2"></i>Error</h6>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body text-center py-3">
                    <i class="bi bi-exclamation-circle text-danger display-4 mb-2 d-block"></i>
                    <p class="mb-0">@TempData["Error"]</p>
                </div>
                <div class="modal-footer border-0 justify-content-center pt-0">
                    <button type="button" class="btn btn-danger rounded-pill px-4" data-bs-dismiss="modal">OK</button>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        // Confirmation modal
        var pendingForm = null;
        var pendingVerifyCallback = null;
        document.querySelectorAll('[data-confirm]').forEach(function (el) {
            el.addEventListener('click', function (e) {
                e.preventDefault();
                pendingForm = this.closest('form');
                document.getElementById('confirmMessage').innerHTML = '<p class="mb-0 fw-medium">' + this.dataset.confirm + '</p>';
                new bootstrap.Modal(document.getElementById('confirmModal')).show();
            });
        });
        document.getElementById('confirmBtn').addEventListener('click', function () {
            if (pendingVerifyCallback) {
                pendingVerifyCallback();
                pendingVerifyCallback = null;
            } else if (pendingForm) {
                pendingForm.submit();
            }
        });

        // Documents modal
        document.querySelectorAll('.btn-view-docs').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var id = this.dataset.employerId;
                fetch('/Admin/EmployerDocuments/' + id)
                    .then(function (r) { return r.text(); })
                    .then(function (html) {
                        var wrapper = document.getElementById('employerDocsWrapper');
                        if (!wrapper) {
                            wrapper = document.createElement('div');
                            wrapper.id = 'employerDocsWrapper';
                            document.body.appendChild(wrapper);
                        }
                        wrapper.innerHTML = html;
                        wrapper.querySelectorAll('.verify-edoc-form').forEach(function (form) {
                            form.addEventListener('submit', function (e) {
                                e.preventDefault();
                                var row = e.target.closest('tr');
                                var docId = row.id.replace('edoc-row-', '');
                                var formData = new FormData(form);
                                document.getElementById('confirmMessage').innerHTML = '<p class="mb-0 fw-medium">Verify this document?</p>';
                                pendingVerifyCallback = function () {
                                    fetch(form.action, {
                                        method: 'POST',
                                        body: new URLSearchParams(formData),
                                        headers: { 'RequestVerificationToken': formData.get('__RequestVerificationToken') }
                                    }).then(function (r) { return r.json(); })
                                    .then(function (data) {
                                        if (data.success) {
                                            document.getElementById('edoc-status-' + docId).innerHTML = '<span class="badge bg-success rounded-pill"><i class="bi bi-check-circle me-1"></i>Verified</span>';
                                            document.getElementById('edoc-action-' + docId).innerHTML = '<span class="text-success small"><i class="bi bi-check-circle-fill me-1"></i>Done</span>';
                                            bootstrap.Modal.getInstance(document.getElementById('confirmModal')).hide();
                                        }
                                    });
                                };
                                new bootstrap.Modal(document.getElementById('confirmModal')).show();
                            });
                        });
                        var modal = new bootstrap.Modal(document.getElementById('employerDocsModal'));
                        modal.show();
                    });
            });
        });

        // Activities modal
        document.querySelectorAll('.btn-view-activities').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var id = this.dataset.employerId;
                fetch('/Admin/EmployerActivities/' + id)
                    .then(function (r) { return r.text(); })
                    .then(function (html) {
                        var wrapper = document.getElementById('employerActivitiesWrapper');
                        if (!wrapper) {
                            wrapper = document.createElement('div');
                            wrapper.id = 'employerActivitiesWrapper';
                            document.body.appendChild(wrapper);
                        }
                        wrapper.innerHTML = html;
                        var modal = new bootstrap.Modal(document.getElementById('employerActivitiesModal'));
                        modal.show();
                    });
            });
        });

        // Communication modal
        var activeEmployerId = null;
        document.querySelectorAll('.btn-communicate').forEach(function (btn) {
            btn.addEventListener('click', function () {
                activeEmployerId = this.dataset.employerId;
                document.getElementById('emailEmployerId').value = activeEmployerId;
                document.getElementById('smsEmployerId').value = activeEmployerId;
                new bootstrap.Modal(document.getElementById('commModal')).show();
            });
        });

        @if (TempData["Success"] != null)
        {
            <text>
            document.addEventListener('DOMContentLoaded', function () {
                new bootstrap.Modal(document.getElementById('successModal')).show();
            });
            </text>
        }
        @if (TempData["Error"] != null)
        {
            <text>
            document.addEventListener('DOMContentLoaded', function () {
                new bootstrap.Modal(document.getElementById('errorModal')).show();
            });
            </text>
        }
    </script>
}

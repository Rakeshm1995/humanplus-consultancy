@{
    ViewData["Title"] = "Contact";
}

<div class="contact-hero py-5 text-white">
    <div class="container text-center py-4">
        <h1 class="display-5 fw-bold">Contact <span class="text-gold">Us</span></h1>
        <p class="lead mx-auto" style="max-width: 600px; opacity: 0.92;">
            Get in touch with HumanPlus Manpower Consultancy
        </p>
    </div>
</div>

<div class="container py-5">
    <div class="row g-4 mb-5">
        <div class="col-md-6 col-lg-3">
            <div class="card service-card h-100 text-center p-4 border-0 shadow-sm">
                <div class="card-body">
                    <div class="icon-circle mb-3" style="background: rgba(14,116,144,0.1); color: #0e7490;">
                        <i class="bi bi-geo-alt-fill"></i>
                    </div>
                    <h6 class="fw-semibold mb-1">Our Address</h6>
                    <p class="card-text text-muted small mb-0">HumanPlus Manpower Consultancy<br />Bhubaneswar, Odisha, India</p>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="card service-card h-100 text-center p-4 border-0 shadow-sm">
                <div class="card-body">
                    <div class="icon-circle mb-3" style="background: rgba(245,158,11,0.1); color: #f59e0b;">
                        <i class="bi bi-telephone-fill"></i>
                    </div>
                    <h6 class="fw-semibold mb-1">Phone</h6>
                    <p class="card-text text-muted small mb-0">+91-9876543210</p>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="card service-card h-100 text-center p-4 border-0 shadow-sm">
                <div class="card-body">
                    <div class="icon-circle mb-3" style="background: rgba(225,29,72,0.1); color: #e11d48;">
                        <i class="bi bi-envelope-fill"></i>
                    </div>
                    <h6 class="fw-semibold mb-1">Email</h6>
                    <p class="card-text text-muted small mb-0">info@humanplus.in</p>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="card service-card h-100 text-center p-4 border-0 shadow-sm">
                <div class="card-body">
                    <div class="icon-circle mb-3" style="background: rgba(79,70,229,0.1); color: #4f46e5;">
                        <i class="bi bi-clock-fill"></i>
                    </div>
                    <h6 class="fw-semibold mb-1">Office Hours</h6>
                    <p class="card-text text-muted small mb-0">Mon-Sat: 10:00 AM - 6:00 PM<br />Sunday: Closed</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card h-100 border-0 shadow-sm" style="border-left: 4px solid #0e7490 !important; border-radius: 12px;">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <div class="icon-circle flex-shrink-0" style="background: rgba(14,116,144,0.1); color: #0e7490; width: 48px; height: 48px; font-size: 1.2rem;">
                            <i class="bi bi-person-badge"></i>
                        </div>
                        <h5 class="fw-semibold mb-0">For Candidates</h5>
                    </div>
                    <p class="text-muted mb-0">Register online, download your form, and visit our office with <strong>₹200</strong> for one-time registration.</p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card h-100 border-0 shadow-sm" style="border-left: 4px solid #f59e0b !important; border-radius: 12px;">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <div class="icon-circle flex-shrink-0" style="background: rgba(245,158,11,0.1); color: #f59e0b; width: 48px; height: 48px; font-size: 1.2rem;">
                            <i class="bi bi-building"></i>
                        </div>
                        <h5 class="fw-semibold mb-0">For Employers</h5>
                    </div>
                    <p class="text-muted mb-0">Register your company online and visit our office with <strong>₹700</strong> for yearly registration. Get candidates at <strong>₹300/month</strong> each.</p>
                </div>
            </div>
        </div>
    </div>
</div>
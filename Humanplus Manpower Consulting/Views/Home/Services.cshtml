        <div class="cta-section py-5 text-white">
            <div class="container text-center py-3">
                <h3 class="fw-bold mb-2">Ready to Get Started?</h3>

                @if (!User.Identity!.IsAuthenticated)
                {
                    <p class="mb-4" style="opacity: 0.9; font-size: 1.1rem;">
                        Register today and find the right talent or the right job
                    </p>

                    <a asp-controller="Account"
                       asp-action="Register"
                       asp-route-role="Employer"
                       class="btn btn-gold btn-lg me-2 mb-2">
                        Register as Employer
                    </a>

                    <a asp-controller="Account"
                       asp-action="Register"
                       asp-route-role="JobSeeker"
                       class="btn btn-outline-light btn-lg mb-2">
                        Register as Job Seeker
                    </a>
                }
                else
                {
                    <p class="mb-4" style="opacity: 0.9; font-size: 1.1rem;">
                        Welcome back! Continue from your dashboard.
                    </p>

                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-controller="Admin"
                           asp-action="Dashboard"
                           class="btn btn-gold btn-lg">
                            Go to Admin Dashboard
                        </a>
                    }
                    else if (User.IsInRole("Employer"))
                    {
                        <a asp-controller="Employer"
                           asp-action="Dashboard"
                           class="btn btn-gold btn-lg">
                            Go to Employer Dashboard
                        </a>
                    }
                    else if (User.IsInRole("JobSeeker"))
                    {
                        <a asp-controller="Candidate"
                           asp-action="Dashboard"
                           class="btn btn-gold btn-lg">
                            Go to Dashboard
                        </a>
                    }
                }
            </div>
        </div>
    @* </div>
</div> *@
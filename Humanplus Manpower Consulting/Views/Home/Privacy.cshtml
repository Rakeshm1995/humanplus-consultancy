@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="services-hero py-5 text-white">
    <div class="container text-center py-4">
        <h1 class="display-5 fw-bold">Privacy <span class="text-gold">Policy</span></h1>
        <p class="lead mx-auto" style="max-width: 600px; opacity: 0.92;">
            How we collect, use, and protect your personal information
        </p>
    </div>
</div>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 p-4 p-lg-5">
                <h5 class="fw-semibold mb-3"><i class="bi bi-shield-check text-primary me-2"></i>Information We Collect</h5>
                <p class="text-muted">We collect personal information such as your name, email address, phone number, educational qualifications, work experience, and identity documents (Aadhaar, police verification) solely for recruitment and placement purposes.</p>

                <hr class="my-4" />

                <h5 class="fw-semibold mb-3"><i class="bi bi-people text-primary me-2"></i>How We Use Your Information</h5>
                <p class="text-muted">Your information is used to match your profile with suitable job opportunities from our partner employers, process registrations, verify credentials, and facilitate the recruitment lifecycle.</p>

                <hr class="my-4" />

                <h5 class="fw-semibold mb-3"><i class="bi bi-lock text-primary me-2"></i>Data Protection</h5>
                <p class="text-muted">We implement reasonable security measures to protect your personal data from unauthorized access, alteration, disclosure, or destruction. Your data is stored securely and accessed only by authorized personnel.</p>

                <hr class="my-4" />

                <h5 class="fw-semibold mb-3"><i class="bi bi-clock-history text-primary me-2"></i>Data Retention</h5>
                <p class="text-muted">We retain your personal information for as long as necessary to fulfill the purposes outlined in this policy, or as required by applicable law. You may request deletion of your data by contacting us.</p>

                <hr class="my-4" />

                <h5 class="fw-semibold mb-3"><i class="bi bi-envelope text-primary me-2"></i>Contact Us</h5>
                <p class="text-muted mb-0">If you have any questions about this privacy policy, please contact us at <strong>info@humanplus.in</strong> or visit our office in Bhubaneswar, Odisha.</p>
            </div>
        </div>
    </div>
</div>
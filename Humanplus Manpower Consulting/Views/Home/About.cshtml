@{
    ViewData["Title"] = "About";
}

<div class="hero-section-wrapper page-hero-section" style="background-image: url('/images/about-hero.jpg');">
    <div class="hero-overlay-fixed">
        <div class="container text-center text-white">
            <h1 class="display-5 fw-bold hero-title">About <span class="text-gold">HumanPlus</span></h1>
            <p class="lead mx-auto mb-3" style="max-width: 700px;">
                Based in Bhubaneswar, Odisha, we are a dedicated manpower consultancy firm bridging the gap between talented job seekers and reputable employers.
            </p>
            <p class="mx-auto" style="max-width: 750px; opacity: 0.85; font-size: 1.05rem;">
                We provide skilled, semi-skilled, and unskilled manpower to various sectors including Healthcare, Hotels &amp; Hospitality, Industrial Production, Manufacturing, Housekeeping &amp; Facility Management, Security Services, Logistics &amp; Warehousing, Retail &amp; Sales, and other human-based service industries across Odisha.
            </p>
        </div>
    </div>
</div>

<div class="container py-5">
    <div class="row justify-content-center mb-5">
        <div class="col-lg-8">
            <div class="mission-card p-4 p-lg-5">
                <div class="d-flex align-items-start gap-3">
                    <div class="mission-icon flex-shrink-0">
                        <i class="bi bi-bullseye"></i>
                    </div>
                    <div>
                        <h3 class="fw-bold mb-2">Our Mission</h3>
                        <p class="lead mb-0" style="color: #4b5563;">
                            To reduce unemployment in Odisha by connecting skilled individuals with the right opportunities while providing industries with reliable, pre-screened manpower.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="text-center mb-5">
        <h3 class="fw-bold section-title">Industries <span class="text-gold">We Serve</span></h3>
        <p class="text-muted">We cater to a wide range of industries across Odisha</p>
    </div>

    <div class="row justify-content-center mb-5">
        <div class="col-lg-10">
            <div class="d-flex flex-wrap justify-content-center gap-2">
                <span class="industry-pill" style="background: rgba(14,116,144,0.1); color: #0e7490; border-color: rgba(14,116,144,0.2);"><i class="bi bi-heart-pulse me-1"></i> Healthcare</span>
                <span class="industry-pill" style="background: rgba(245,158,11,0.1); color: #b45309; border-color: rgba(245,158,11,0.2);"><i class="bi bi-building-hotel me-1"></i> Hotels &amp; Hospitality</span>
                <span class="industry-pill" style="background: rgba(79,70,229,0.1); color: #4338ca; border-color: rgba(79,70,229,0.2);"><i class="bi bi-gear-wide-connected me-1"></i> Industrial Production</span>
                <span class="industry-pill" style="background: rgba(16,185,129,0.1); color: #059669; border-color: rgba(16,185,129,0.2);"><i class="bi bi-building-gear me-1"></i> Manufacturing</span>
                <span class="industry-pill" style="background: rgba(239,68,68,0.1); color: #dc2626; border-color: rgba(239,68,68,0.2);"><i class="bi bi-broom me-1"></i> Housekeeping &amp; Facility Management</span>
                <span class="industry-pill" style="background: rgba(107,114,128,0.1); color: #4b5563; border-color: rgba(107,114,128,0.2);"><i class="bi bi-shield-lock me-1"></i> Security Services</span>
                <span class="industry-pill" style="background: rgba(14,116,144,0.1); color: #0e7490; border-color: rgba(14,116,144,0.2);"><i class="bi bi-truck me-1"></i> Logistics &amp; Warehousing</span>
                <span class="industry-pill" style="background: rgba(245,158,11,0.1); color: #b45309; border-color: rgba(245,158,11,0.2);"><i class="bi bi-shop me-1"></i> Retail &amp; Sales</span>
            </div>
        </div>
    </div>

    <div class="text-center mb-5">
        <h3 class="fw-bold section-title">Why Choose <span class="text-gold">Us</span>?</h3>
        <p class="text-muted">What sets HumanPlus apart from the rest</p>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card service-card h-100 text-center p-4 border-0 shadow-sm">
                <div class="card-body">
                    <div class="icon-circle mb-3" style="background: rgba(14,116,144,0.1); color: #0e7490;">
                        <i class="bi bi-shield-check"></i>
                    </div>
                    <h5 class="fw-semibold">Thorough Verification</h5>
                    <p class="card-text text-muted">Complete document verification including Aadhar and police clearance for every candidate.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card service-card h-100 text-center p-4 border-0 shadow-sm">
                <div class="card-body">
                    <div class="icon-circle mb-3" style="background: rgba(245,158,11,0.1); color: #f59e0b;">
                        <i class="bi bi-wallet2"></i>
                    </div>
                    <h5 class="fw-semibold">Affordable Registration</h5>
                    <p class="card-text text-muted">One-time registration fee of just <strong>₹200</strong> for candidates and <strong>₹700/year</strong> for employers.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card service-card h-100 text-center p-4 border-0 shadow-sm">
                <div class="card-body">
                    <div class="icon-circle mb-3" style="background: rgba(16,185,129,0.1); color: #10b981;">
                        <i class="bi bi-cash-coin"></i>
                    </div>
                    <h5 class="fw-semibold">Monthly Commission</h5>
                    <p class="card-text text-muted">Simple <strong>₹300 per candidate per month</strong> commission model — no hidden charges.</p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card service-card h-100 text-center p-4 border-0 shadow-sm">
                <div class="card-body">
                    <div class="icon-circle mb-3" style="background: rgba(79,70,229,0.1); color: #4f46e5;">
                        <i class="bi bi-geo-alt-fill"></i>
                    </div>
                    <h5 class="fw-semibold">Local Presence</h5>
                    <p class="card-text text-muted">Based right here in Bhubaneswar with personal service and on-ground support for both candidates and employers.</p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card service-card h-100 text-center p-4 border-0 shadow-sm">
                <div class="card-body">
                    <div class="icon-circle mb-3" style="background: rgba(225,29,72,0.1); color: #e11d48;">
                        <i class="bi bi-people-fill"></i>
                    </div>
                    <h5 class="fw-semibold">End-to-End Support</h5>
                    <p class="card-text text-muted">From candidate registration to placement tracking, we handle the entire recruitment lifecycle.</p>
                </div>
            </div>
        </div>
    </div>
</div>